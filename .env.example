# Bhejna Server Configuration - Example

PORT=8080
DB_PATH=/app/data/bhejna.db
INTERNAL_SECRET=your_custom_internal_secret # Secures Go <-> SvelteKit

SUPABASE_URL=https://xyz.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# --- Meta Variables ---
META_APP_SECRET=your_meta_app_secret # Found in Meta App Dashboard -> Settings -> Basic
META_VERIFY_TOKEN=bhejna_webhook_verify_2026 # The string you just made up
META_SYSTEM_USER_TOKEN= # (Leave blank for now. See note below).
